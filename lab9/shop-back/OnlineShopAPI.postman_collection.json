        {"name": "Update Product", "request": {"method": "PUT", "url": "http://127.0.0.1:8000/api/products/1/", "body": {"mode": "raw", "raw": "{\"name\": \"Updated\", \"price\": 2000, \"description\": \"Updated\", \"count\": 5, \"is_active\": true, \"category\": 1}", "options": {"raw": {"language": "json"}}}}},
